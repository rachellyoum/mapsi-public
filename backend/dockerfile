# 1. Use lightweight Python image
FROM python:3.11-slim

# 2. Prevent Python from writing .pyc files
ENV PYTHONDONTWRITEBYTECODE=1

# 3. Prevent buffering (important for logs in Cloud Run)
ENV PYTHONUNBUFFERED=1

# 4. Set working directory
WORKDIR /backend

# 5. Install system dependencies (optional but common)
RUN apt-get update && apt-get install -y build-essential && rm -rf /var/lib/apt/lists/*

# 6. Copy only requirements first (for better caching)
COPY requirements.txt .

# 7. Install dependencies
RUN pip install --no-cache-dir -r requirements.txt

# 8. Copy rest of project
COPY . .

# 9. Expose port (informational only)
EXPOSE 8080

# 10. Start server (Cloud Run injects PORT env var)
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port $PORT"]